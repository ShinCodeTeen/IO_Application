<Window x:Class="IO_Application.View.ServoMotion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:bi="https://github.com/helluvamatt/BootstrapIcons.Wpf/"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IO_Application.View"
        mc:Ignorable="d"
        Title="ServoMotion" Height="700" MaxWidth="1100" Background="#F1F1F1">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="350"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0" Margin="0 30 0 0">
				<GroupBox  Header="Single Move" Margin="10, 5" Grid.Row="0" FontSize="15" Grid.ColumnSpan="3" >
					<StackPanel>
						<Grid>
							<TextBlock Text="Cmd Pos" VerticalAlignment="Center"/>
							<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
								<TextBox Style="{StaticResource MoveTxb}" Text="{Binding SingleMoveCmdPos}" />
								<TextBlock  Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
							</Grid>
						</Grid>


						<Grid>

							<TextBlock Text="Start Speed" VerticalAlignment="Center"/>
							<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
								<TextBox Style="{StaticResource MoveTxb}" Text="{Binding SingleMoveCmdPos}" />
								<TextBlock  Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
							</Grid>
						</Grid>


						<Grid>
							<TextBlock Text="Move Speed" VerticalAlignment="Center"/>
							<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
								<TextBox Style="{StaticResource MoveTxb}" Text="{Binding SingleMoveCmdPos}"  />
								<TextBlock  Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
							</Grid>
						</Grid>


						<Grid >

							<TextBlock Text="Accel Time" VerticalAlignment="Center"/>
							<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
								<TextBox Style="{StaticResource MoveTxb}" Text="{Binding AccelTime}" />
								<TextBlock  Text="[msec]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
							</Grid>
						</Grid>


						<Grid >

							<TextBlock Text="Decel Time" VerticalAlignment="Center"/>
							<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
								<TextBox Style="{StaticResource MoveTxb}" Text="{Binding DecelTime}" />
								<TextBlock  Text="[msec]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
							</Grid>
						</Grid>


						<Button Content="ABS Move" Style="{StaticResource MoveButton}" HorizontalAlignment="Center" Command="{Binding ABSMoveCommand}" Width="260"/>

						<Grid Margin="5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Button Content="DEC Move" Style="{StaticResource MoveButton}" HorizontalAlignment="Left" Command="{Binding DecMoveCommand}" Width="140"/>
							<Button Content="INC Move" Style="{StaticResource MoveButton}" HorizontalAlignment="Left" Grid.Column="1"  Command="{Binding IncMoveCommand}" Width="140"/>
						</Grid>
					</StackPanel>

				</GroupBox>
				<GroupBox Header="Jog Move" Margin="10,10,10,10" Grid.Row="1" FontSize="15" Grid.ColumnSpan="3" >

					<StackPanel>
						<Grid>
							<TextBlock Text="Max Speed" VerticalAlignment="Center"/>
							<Grid HorizontalAlignment="Right" Width="200">
								<TextBox Style="{StaticResource MoveTxb}" Text="{Binding MaxSpeed}" />
								<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
							</Grid>
						</Grid>
						<Grid>

							<TextBlock Text="Accel/Decel Time" VerticalAlignment="Center" Grid.ColumnSpan="2"/>
							<Grid HorizontalAlignment="Right" Width="200">
								<TextBox Style="{StaticResource MoveTxb}" Text="{Binding AccelDecelTime}"  />
								<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
							</Grid>
						</Grid>
						<Grid Margin="20 5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="211*"/>
								<ColumnDefinition Width="67*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="MinusJogBtn" Content="- Jog" 
                                    Style="{StaticResource MoveButton}" 
                                    HorizontalAlignment="Left"
                                    Width="120"  VerticalAlignment="Center" Margin="7,0,0,0"                                       
                                    >
								<b:Interaction.Triggers>
									<b:EventTrigger EventName="PreviewMouseLeftButtonDown">
										<b:InvokeCommandAction 
											Command="{Binding MinusJogCommand}" 
                                            />
									</b:EventTrigger>
									<b:EventTrigger EventName="PreviewMouseLeftButtonUp">
										<b:InvokeCommandAction Command="{Binding StopMoveCommand}"/>
									</b:EventTrigger>
								</b:Interaction.Triggers>

							</Button>
							<Button Content="+ Jog" 
                                    Style="{StaticResource MoveButton}" 
                                    HorizontalAlignment="Left"  Width="120" Grid.ColumnSpan="2" Margin="150 0 0 0">
								<b:Interaction.Triggers>
									<b:EventTrigger EventName="PreviewMouseLeftButtonDown">
										<b:InvokeCommandAction 
											Command="{Binding PlusJogCommand}" 
                                            CommandParameter="1"/>
									</b:EventTrigger>
									<b:EventTrigger EventName="PreviewMouseLeftButtonUp">
										<b:InvokeCommandAction Command="{Binding StopMoveCommand}"/>
									</b:EventTrigger>
								</b:Interaction.Triggers>
							</Button>

						</Grid>
						<Grid Margin="20 5">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="68*"/>
								<ColumnDefinition Width="151*"/>
								<ColumnDefinition Width="64*"/>
							</Grid.ColumnDefinitions>
							<Button Content="- Limit"  Width="120" Style="{StaticResource MoveButton}" HorizontalAlignment="Left" Command="{Binding MinusLimitCommand}" CommandParameter=""  Grid.ColumnSpan="3"/>
							<Button Content="+ Limit"  Width="120" Style="{StaticResource MoveButton}" HorizontalAlignment="Right" Command="{Binding PlusLimitCommand}" CommandParameter="" Grid.ColumnSpan="3"  />

						</Grid>
					</StackPanel>

				</GroupBox>


			</StackPanel>
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<Grid Grid.Row="0">

					<Border BorderBrush="Gray" CornerRadius="10" BorderThickness="2" Width="300" Height="50" HorizontalAlignment="Right" Margin="0 10 50 10">

						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
							<TextBlock Text="IP: " FontSize="25" FontWeight="Bold" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding CurrentPort.PortName}" FontSize="25" FontWeight="Bold" VerticalAlignment="Center"/>
							<Button  Margin="10 0" Style="{StaticResource ArrowButtonStyle}">

								<bi:BootstrapIcon
                                    Icon="CaretLeftFill"
                                    Width="32"
                                    Height="32"
                                    Foreground="Gray"/>
							</Button>
							<Button Style="{StaticResource ArrowButtonStyle}" >
								<bi:BootstrapIcon
                                    Icon="CaretRightFill"
                                    Width="32"
                                    Height="32"
                                    Foreground="Gray"/>
							</Button>
						</StackPanel>
					</Border>
				</Grid>

				<Grid Grid.Row="1">

					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="350"/>
						<ColumnDefinition Width="*"/>

					</Grid.ColumnDefinitions>
					<StackPanel Orientation="Vertical">
						<GroupBox Header="Position Status" Margin="10 5 10 10" FontSize="15">

							<StackPanel>
								<Grid>
									<TextBlock Text="Cmd Pos" VerticalAlignment="Center"/>
									<Grid Width="200" HorizontalAlignment="Right" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding CmdPos}" HorizontalAlignment="Left"  Background="#7fd674"/>
										<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Grid>
								<Grid>
									<TextBlock Text="Actual Pos" VerticalAlignment="Center"/>
									<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding ActualPos}" HorizontalAlignment="Left"  Background="#7fd674"/>
										<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Grid>
								<Grid>
									<TextBlock Text="Actual Vel" VerticalAlignment="Center"/>
									<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding ActualPos}" HorizontalAlignment="Left" Background="#7fd674"/>
										<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Grid>

								<Grid>

									<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding ActualPos}" HorizontalAlignment="Left" Background="#7fd674"/>
										<TextBlock Text="[RPM]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Grid>
								<Grid>
									<TextBlock Text="Pos Error" VerticalAlignment="Center"/>
									<Grid HorizontalAlignment="Right" Width="200" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding ActualPos}" HorizontalAlignment="Left" Background="#7fd674"/>
										<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Grid>
								<Grid>

									<Grid HorizontalAlignment="Right" Width="200" Margin="5">
										<Button Style="{StaticResource MoveButton}" Content="Clear Position"/>
									</Grid>
								</Grid>

							</StackPanel>

						</GroupBox>
						<GroupBox Header="Origin" Margin="10 5" FontSize="15">

							<StackPanel>
								<Grid>
									<TextBlock Text="Search Speed" VerticalAlignment="Center"/>
									<Grid Width="200" HorizontalAlignment="Right" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding SearchSpeed}" />
										<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Grid>
								<Grid>
									<TextBlock Text="Speed" VerticalAlignment="Center"/>
									<Grid Width="200" HorizontalAlignment="Right" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding Speed}" />
										<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</Grid>
								<Grid>
									<TextBlock Text="Accel/Decel" VerticalAlignment="Center" />
									<Grid Width="200" HorizontalAlignment="Right" Margin="5 0">
										<TextBox Style="{StaticResource MoveTxb}" Text="{Binding AccelDecelTime}"/>
										<TextBlock Text="[pulse]" HorizontalAlignment="Right" VerticalAlignment="Center"/>

									</Grid>
								</Grid>
								<Button Content="Move Origin" Style="{StaticResource MoveButton}" Width="120" HorizontalAlignment="Center" Command="{Binding MoveOriginCommand}" CommandParameter=""/>
							</StackPanel>

						</GroupBox>
					</StackPanel>


					<ItemsControl 
                                    Grid.Column="1"
                                    ItemsSource="{Binding AxisList}"
                                    HorizontalAlignment="Stretch">

						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<UniformGrid Columns="2" Rows="16"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal" Margin="4,0">
									<Border Style="{StaticResource AxisStatusBorder}"/>
									<TextBlock Text="{Binding StatusString}" 
                                                    VerticalAlignment="Center"
                                                    Margin="8,0"/>
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>



				</Grid>

			</Grid>
		</Grid>
		<StackPanel Grid.Row="2" Orientation="Horizontal">
			<Border Height="50" Width="50" Background="#FAFAFAFA" Margin="10" CornerRadius="5">
				<TextBlock Text="SEVO" Style="{StaticResource ServoStatusTbl}" />
			</Border>


			<Button Content="Servo ON" Style="{StaticResource MoveButton}" Margin="10 5" Command="{Binding ServoOnCommand}" CommandParameter="" Width="100"/>
			<Button Content="Servo OFF" Style="{StaticResource MoveButton}" Margin="10 5" Command="{Binding ServoOffCommand}" CommandParameter="" Width="100"/>
			<Button Content="Reset Alarm" Style="{StaticResource MoveButton}"  Margin="10 5" Command="{Binding ResetAlarmCommand}" CommandParameter="" Width="100"/>
			<Button Content="Stop Move" Style="{StaticResource MoveButton}" Margin="10 5" Command="{Binding StopMoveCommand}" CommandParameter="" Width="100"/>
			<Button  Content="Close" Style="{StaticResource MoveButton}"  Margin="400 5 0 5" Command="{Binding CloseCommand}" CommandParameter="" Width="100"/>

		</StackPanel>
	</Grid>

</Window>
