    <Window x:Class="IO_Application.View.IoMotion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IO_Application.View"

        xmlns:bi="https://github.com/helluvamatt/BootstrapIcons.Wpf/"
        
        mc:Ignorable="d"
        Title="IO Status Board" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid>
            <Border BorderBrush="Gray" 
                    CornerRadius="10" 
                    BorderThickness="2" Width="300" 
                    Height="50" 
                    HorizontalAlignment="Right" 
                    Margin="0 10 50 10">

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                    <TextBlock Text="IP: " 
                               FontSize="25" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentPortModel.PortName}" 
                               FontSize="25" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <Button  Margin="10 0" Style="{StaticResource ArrowButtonStyle}" 
                             Command="{Binding PrevIpCommand }">

                        <bi:BootstrapIcon
                             Icon="CaretLeftFill"
                             Width="32"
                             Height="32"
                             Foreground="Gray"/>
                    </Button>
                    <Button Style="{StaticResource ArrowButtonStyle}" Command="{Binding NextIpCommand}" >
                        <bi:BootstrapIcon
                             Icon="CaretRightFill"
                             Width="32"
                             Height="32"
                             Foreground="Gray"/>
                    </Button>
					
                </StackPanel>
            </Border>
            
            
        </Grid>
        <ScrollViewer Grid.Row="1" 
                      HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto" >

            <UniformGrid Rows="1" Columns="2" >
                <ItemsControl ItemsSource="{Binding InputPins}" >
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Vertical" 
                                       Height="320" 
                                       ItemWidth="150" 
                                       ItemHeight="40"></WrapPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10 0">
                                <Button Style="{StaticResource InIoButton}"/>
                                <TextBlock Text="{Binding Type}" VerticalAlignment="Center" Margin="10 0 0 0"/>
                                <TextBlock Text="{Binding PinNumber}" VerticalAlignment="Center" Margin="5 0 0 0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding OutputPins}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Vertical" 
                                       Height="320" 
                                       ItemWidth="150" 
                                       ItemHeight="40" ></WrapPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10 0">
                                <Button Style="{StaticResource OutIoButton}" 
                                        Command="{Binding DataContext.ToggleOutputCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding}"/>
                                <TextBlock Text="{Binding Type}" 
                                           VerticalAlignment="Center" 
                                           Margin="10 0 0 0"/>
                                <TextBlock Text="{Binding PinNumber}" 
                                           VerticalAlignment="Center" 
                                           Margin="5 0 0 0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>


                </ItemsControl>

            </UniformGrid>

        </ScrollViewer>

      
        
            
        

        </Grid>
</Window>
