<Window x:Class="IO_Application.View.DialogWindow.Loading"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IO_Application.View.DialogWindow"
        mc:Ignorable="d"
        Title="Loading"
		Height="200" 
		Width="250" 
		WindowStyle="None"
		WindowStartupLocation="CenterScreen"
		
		AllowsTransparency="True"
		Background="Transparent"
		ResizeMode="NoResize"
		
		>
	<Grid>
		<Border BorderBrush="#007ACC" Background="#FAFAFA" BorderThickness="3" CornerRadius="12">
			<StackPanel Margin="5">


				<TextBlock Text="{Binding DataContext.Message}" 
                       FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,5,0,10" />

				<ProgressBar x:Name="pbProgress" Grid.Row="1" Height="24" 
                         Minimum="0" Maximum="100" Value="0"
                         Margin="0,10" />

				<TextBlock x:Name="txtPercent"  
                       Text="0%" HorizontalAlignment="Center" 
                       FontSize="14" FontWeight="Medium" Margin="0,8,0,15"/>

				<Button  Content="Hủy" Width="120" Height="40" 
                     Foreground="White" FontSize="14"
                    Click="CancelButton_Click"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>
